<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Loomé – Cotton Weave</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #f0ede8;
      --white: #faf8f5;
      --dark: #1e1e1b;
      --olive: #4a5240;
      --sand: #e2d9ce;
      --pink: #e8b4b0;
      --text-muted: #7a7570;
      --border: #ddd8d0;
    }

    body {
      font-family: 'Jost', sans-serif;
      background-color: var(--bg);
      color: var(--dark);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    .site_header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 52px;
      background: var(--bg);
    }

    .header_logo {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 400;
      letter-spacing: -0.5px;
      color: var(--dark);
      text-decoration: none;
    }

    .header_logo span {
      font-style: italic;
    }

    .header_nav {
      display: flex;
      align-items: center;
      gap: 36px;
      list-style: none;
    }

    .header_nav a {
      font-size: 13.5px;
      font-weight: 400;
      letter-spacing: 0.5px;
      color: var(--dark);
      text-decoration: none;
      opacity: 0.75;
      transition: opacity 0.2s;
    }

    .header_nav a:hover { opacity: 1; }

    .header_nav .nav_active {
      opacity: 1;
      position: relative;
    }

    .header_nav .nav_active::after {
      content: '';
      display: block;
      width: 100%;
      height: 1.5px;
      background: var(--dark);
      margin-top: 3px;
    }

    .header_icons {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .cart_btn {
      position: relative;
      background: none;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
    }

    .cart_btn svg { width: 22px; height: 22px; }

    .cart_count {
      position: absolute;
      top: -6px;
      right: -7px;
      background: var(--dark);
      color: #fff;
      font-size: 9px;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Jost', sans-serif;
    }

    .menu_btn {
      background: none;
      border: none;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .menu_btn span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--dark);
    }

    /* ── MAIN LAYOUT ── */
    .product_wrapper {
      display: grid;
      grid-template-columns: 370px 1fr 100px;
      gap: 0;
      padding: 20px 52px 0;
      min-height: calc(100vh - 80px);
    }

    /* ── LEFT PANEL ── */
    .product_info {
      padding-right: 32px;
      padding-top: 10px;
      position: relative;
    }

    .collection_tag {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 22px;
    }

    .collection_tag svg {
      width: 22px;
      height: 22px;
      opacity: 0.6;
    }

    .collection_tag span {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .product_title {
      font-family: 'Playfair Display', serif;
      font-size: 72px;
      line-height: 1.0;
      font-weight: 400;
      color: var(--dark);
      margin-bottom: 22px;
    }

    .title_divider {
      width: 44px;
      height: 1px;
      background: var(--olive);
      margin-bottom: 20px;
    }

    .product_desc {
      font-size: 13.5px;
      font-weight: 300;
      line-height: 1.75;
      color: var(--text-muted);
      max-width: 300px;
      margin-bottom: 28px;
    }

    .color_section label {
      font-size: 12.5px;
      font-weight: 400;
      letter-spacing: 0.4px;
      color: var(--dark);
      margin-bottom: 12px;
      display: block;
    }

    .color_dots {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .color_dot {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.2s;
    }

    .color_dot:hover { border-color: var(--dark); }

    .dot_olive { background: #4a5240; }
    .dot_sand  { background: #ddd4c6; }
    .dot_pink  { background: #e8b4b0; }

    .details_block {
      margin-top: 26px;
    }

    .details_heading {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      font-weight: 500;
      letter-spacing: 0.3px;
      margin-bottom: 14px;
    }

    .details_heading::after {
      content: '';
      display: block;
      width: 22px;
      height: 1px;
      background: var(--dark);
    }

    .details_text {
      font-size: 12.5px;
      font-weight: 300;
      line-height: 1.8;
      color: var(--text-muted);
      max-width: 300px;
    }

    /* badges row */
    .badges_row {
      display: flex;
      align-items: flex-start;
      gap: 0;
      margin-top: 40px;
      border-top: 1px solid var(--border);
      padding-top: 24px;
    }

    .badge_item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      text-align: center;
      padding: 0 12px;
    }

    .badge_item + .badge_item {
      border-left: 1px solid var(--border);
    }

    .badge_item svg {
      width: 30px;
      height: 30px;
      color: var(--text-muted);
    }

    .badge_item p {
      font-size: 11.5px;
      font-weight: 500;
      line-height: 1.4;
      color: var(--dark);
    }

    /* ── CENTER — IMAGE ── */
    .product_stage {
      position: relative;
      display: flex;
      justify-content: center;
    }

    .main_image_wrap {
      position: relative;
      width: 100%;
      max-width: 560px;
      border-radius: 18px;
      overflow: hidden;
      height: 570px;
    }

    .main_image_wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .price_pill {
      position: absolute;
      top: 22px;
      left: 22px;
      background: rgba(250,248,245,0.9);
      backdrop-filter: blur(6px);
      border-radius: 50px;
      padding: 9px 20px;
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 400;
      color: var(--dark);
    }

    .rating_pill {
      position: absolute;
      top: 22px;
      right: 22px;
      background: rgba(250,248,245,0.9);
      backdrop-filter: blur(6px);
      border-radius: 50px;
      padding: 9px 18px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      font-weight: 400;
      color: var(--dark);
    }

    .stars {
      display: flex;
      gap: 3px;
    }

    .stars span {
      color: #c8a96a;
      font-size: 14px;
    }

    .vertical_label {
      position: absolute;
      right: -14px;
      top: 50%;
      transform: translateY(-50%) rotate(90deg);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--text-muted);
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .vertical_label::before {
      content: '';
      display: block;
      width: 40px;
      height: 1px;
      background: var(--text-muted);
    }

    .add_bag_btn {
      position: absolute;
      bottom: 22px;
      right: 22px;
      background: var(--olive);
      color: #fff;
      border: none;
      border-radius: 50%;
      width: 96px;
      height: 96px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      cursor: pointer;
      font-family: 'Jost', sans-serif;
      font-size: 12px;
      font-weight: 400;
      letter-spacing: 0.3px;
      transition: background 0.2s, transform 0.15s;
    }

    .add_bag_btn:hover {
      background: #3a4130;
      transform: scale(1.04);
    }

    .add_bag_btn svg { width: 22px; height: 22px; }

    /* trust strip */
    .trust_strip {
      display: flex;
      align-items: center;
      background: var(--white);
      border-radius: 16px;
      margin-top: 18px;
      overflow: hidden;
    }

    .trust_item {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 18px 20px;
    }

    .trust_item + .trust_item {
      border-left: 1px solid var(--border);
    }

    .trust_item svg {
      width: 26px;
      height: 26px;
      flex-shrink: 0;
      color: var(--text-muted);
    }

    .trust_item div strong {
      display: block;
      font-size: 12px;
      font-weight: 500;
      color: var(--dark);
    }

    .trust_item div span {
      font-size: 11.5px;
      font-weight: 300;
      color: var(--text-muted);
    }

    /* ── RIGHT — THUMBNAILS ── */
    .thumb_rail {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding-left: 18px;
      padding-top: 4px;
    }

    .thumb_item {
      width: 72px;
      height: 72px;
      border-radius: 10px;
      overflow: hidden;
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.2s;
      flex-shrink: 0;
    }

    .thumb_item.active_thumb {
      border-color: var(--dark);
    }

    .thumb_item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* leaf bg decoration */
    .leaf_bg {
      position: fixed;
      top: 60px;
      left: -40px;
      opacity: 0.07;
      pointer-events: none;
      z-index: 0;
      width: 260px;
    }

    .product_wrapper { position: relative; z-index: 1; }
  </style>
</head>
<body>

  <!-- Leaf decoration -->
  <svg class="leaf_bg" viewBox="0 0 300 500" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M150 480 C80 400 20 300 30 180 C40 80 120 20 150 10 C180 20 260 80 270 180 C280 300 220 400 150 480Z" fill="#4a5240"/>
    <line x1="150" y1="480" x2="150" y2="10" stroke="#4a5240" stroke-width="2"/>
    <line x1="150" y1="200" x2="80" y2="140" stroke="#4a5240" stroke-width="1.5"/>
    <line x1="150" y1="260" x2="210" y2="200" stroke="#4a5240" stroke-width="1.5"/>
    <line x1="150" y1="320" x2="90" y2="270" stroke="#4a5240" stroke-width="1.5"/>
    <line x1="150" y1="370" x2="200" y2="330" stroke="#4a5240" stroke-width="1.5"/>
  </svg>

  <!-- HEADER -->
  <header class="site_header">
    <a href="#" class="header_logo">loom<span>é</span>.</a>

    <nav>
      <ul class="header_nav">
        <li><a href="#">Home</a></li>
        <li><a href="#" class="nav_active">Shop</a></li>
        <li><a href="#">Collection</a></li>
        <li><a href="#">About</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
    </nav>

    <div class="header_icons">
      <button class="cart_btn" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="cart_count">2</span>
      </button>
      <button class="menu_btn" aria-label="Menu">
        <span></span><span></span>
      </button>
    </div>
  </header>

  <!-- PRODUCT SECTION -->
  <main class="product_wrapper">

    <!-- LEFT -->
    <aside class="product_info">

      <div class="collection_tag">
        <!-- leaf icon -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22c0 0-8-4-8-12a8 8 0 0116 0c0 8-8 12-8 12z"/>
          <line x1="12" y1="22" x2="12" y2="10"/>
        </svg>
        <span>New Collection</span>
      </div>

      <h1 class="product_title">a cotton<br>weave</h1>
      <div class="title_divider"></div>

      <p class="product_desc">
        Crafted from 100% organic cotton with a soft, breathable feel. Perfect for all seasons and everyday elegance.
      </p>

      <div class="color_section">
        <label>colors</label>
        <div class="color_dots">
          <div class="color_dot dot_olive" title="Olive"></div>
          <div class="color_dot dot_sand" title="Sand"></div>
          <div class="color_dot dot_pink" title="Pink"></div>
        </div>
      </div>

      <div class="details_block">
        <h3 class="details_heading">Details</h3>
        <p class="details_text">
          Lorem ipsum dolor sit amet, consectetur adipisicing elit. Accusamus, sapiente. Ipsam maiores nemo, quidem veniam et atque suscipit, saepe doloribus ab molestiae deserunt? Totam natus eligendi neque.
        </p>
      </div>

      <div class="badges_row">
        <div class="badge_item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 22c0 0-8-4-8-12a8 8 0 0116 0c0 8-8 12-8 12z"/>
            <line x1="12" y1="22" x2="12" y2="10"/>
          </svg>
          <p>Organic<br>Cotton</p>
        </div>
        <div class="badge_item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
          </svg>
          <p>Soft &amp;<br>Lightweight</p>
        </div>
        <div class="badge_item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/>
          </svg>
          <p>Handmade<br>Weave</p>
        </div>
      </div>

    </aside>

    <!-- CENTER -->
    <section class="product_stage">
      <div>
        <div class="main_image_wrap">

          <!-- placeholder main image — replace src with real photo -->
          <img
            src="https://images.unsplash.com/photo-1487222477894-8943e31ef7b2?w=800&q=80"
            alt="Cotton Twill Scarf"
          />

          <div class="price_pill">$488</div>

          <div class="rating_pill">
            Rating
            <div class="stars">
              <span>★</span><span>★</span><span>★</span><span>★</span><span style="opacity:0.35">★</span>
            </div>
          </div>

          <div class="vertical_label">cotton twill scarf</div>

          <button class="add_bag_btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            Add to bag
          </button>

        </div>

        <!-- Trust strip -->
        <div class="trust_strip">
          <div class="trust_item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <div>
              <strong>Secure Payment</strong>
            </div>
          </div>
          <div class="trust_item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="1" y="3" width="15" height="13" rx="1"/>
              <path d="M16 8h4l3 4v4h-7V8z"/>
              <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <div>
              <strong>Free Shipping</strong>
              <span>Over $100</span>
            </div>
          </div>
          <div class="trust_item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="1 4 1 10 7 10"/>
              <path d="M3.51 15a9 9 0 102.13-9.36L1 10"/>
            </svg>
            <div>
              <strong>Easy Returns</strong>
              <span>30 Days</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- RIGHT THUMBNAILS -->
    <aside class="thumb_rail">
      <div class="thumb_item active_thumb">
        <img src="https://images.unsplash.com/photo-1487222477894-8943e31ef7b2?w=200&q=70" alt="Look 1"/>
      </div>
      <div class="thumb_item">
        <img src="https://images.unsplash.com/photo-1601762603339-fd61e28b698a?w=200&q=70" alt="Scarf folded"/>
      </div>
      <div class="thumb_item">
        <img src="https://images.unsplash.com/photo-1617627143750-d86bc21e42bb?w=200&q=70" alt="Texture close-up"/>
      </div>
      <div class="thumb_item">
        <img src="https://images.unsplash.com/photo-1520903920243-00d872a2d1c9?w=200&q=70" alt="Cotton detail"/>
      </div>
    </aside>

  </main>

  <script>
    // thumbnail switching
    var thumbs = document.querySelectorAll('.thumb_item');
    var main_img = document.querySelector('.main_image_wrap img');

    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbs.forEach(function(t) { t.classList.remove('active_thumb'); });
        this.classList.add('active_thumb');
        var src = this.querySelector('img').src;
        main_img.src = src;
      });
    });

    // color selection ring
    var dots = document.querySelectorAll('.color_dot');
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        dots.forEach(function(d) { d.style.border = '2px solid transparent'; });
        this.style.border = '2px solid #1e1e1b';
      });
    });
  </script>
</body>
</html>
